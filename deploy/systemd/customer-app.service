[Unit]
Description=ATM Customer Web App (Gunicorn)
After=network.target

[Service]
User=atm
Group=www-data
WorkingDirectory=/opt/atm-app
EnvironmentFile=/opt/atm-app/.env
ExecStart=/opt/atm-app/atm_venv/bin/gunicorn -w 3 -b 127.0.0.1:8000 customer_app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
