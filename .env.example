# Copy to `.env` for non-sensitive runtime options only.
# Never commit `.env` to git.
#
# Sensitive values (CONTRACT_ADDRESS, ETH_PRIVATE_KEY, FLASK_SECRET_KEY,
# MIDDLEWARE_SERVICE_TOKEN) must be stored in the OS keychain only.
#
# Middleware DB + tunables: prefer keychain (same as above).
#   python3 scripts/manage_secrets.py set MIDDLEWARE_DB_URL
#   python3 scripts/manage_secrets.py show MIDDLEWARE_DB_URL
# .env entries below are optional fallbacks for non-sensitive settings.

# Layer 2 (middleware) — used by customer_app.py
MIDDLEWARE_URL=http://localhost:8000

# Layer 3 (Spring Boot Core Banking) — used by middleware (deposit/withdraw + worker)
CORE_BANKING_URL=http://localhost:8080

# Middleware Postgres — prefer keychain; optional fallback here:
# MIDDLEWARE_DB_URL=postgresql+psycopg://mwuser:mwpass@localhost:5433/mwuser

# Sepolia RPC endpoints (middleware writes the canonical hash here)
ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_RPC_FALLBACK_URLS=https://sepolia.drpc.org,https://1rpc.io/sepolia

# Reconciliation worker tunables (all optional; defaults are sane)
WORKER_RETRY_INTERVAL_SECONDS=30
WORKER_CONFIRM_INTERVAL_SECONDS=60
WORKER_TAMPER_INTERVAL_SECONDS=300
WORKER_TAMPER_LOOKBACK_HOURS=24
WORKER_MAX_SUBMIT_ATTEMPTS=8

# Customer UI idle session (prefer keychain; optional .env fallback):
# ATM_IDLE_PROMPT_SECONDS=120      # show "another transaction?" after 2 min idle
# ATM_PROMPT_TIMEOUT_SECONDS=60      # auto sign-out if no answer within 60s
# ATM_SESSION_TTL_SECONDS=900        # hard server cap (15 min)

# Middleware DB retention (optional .env fallback; prefer keychain)
# TRANSACTION_LOG_RETENTION_DAYS=90   # delete audit rows older than 90 days (0 = keep forever)
# RETENTION_CLEANUP_INTERVAL_SECONDS=3600

# Optional: customer_app bind port (honcho / `python customer_app.py`).
# Default 5000 often conflicts with macOS AirPlay Receiver.
# PORT=5001
