# Copy to `.env` for non-sensitive runtime options only.
# Never commit `.env` to git.
#
# Sensitive values (CONTRACT_ADDRESS, ETH_PRIVATE_KEY, DATABASE_URL,
# FLASK_SECRET_KEY) must be stored in the OS keychain.
# Run: python3 scripts/manage_secrets.py set <NAME>
# See README section 3.1.

ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_RPC_FALLBACK_URLS=https://sepolia.drpc.org,https://1rpc.io/sepolia

INDEXER_INTERVAL_SECONDS=3

# Users live in SQLite (see secure_user_db.py). Optional paths (defaults shown):
# ATM_SECURE_USER_DB=secure_users.db
# ATM_SECURE_USER_KEY=user_db_aes256.key

# Optional: customer_app bind port (honcho / `python customer_app.py`).
# Default 5000 often conflicts with macOS AirPlay Receiver.
# PORT=5001
